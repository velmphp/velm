{
    "name": "velmphp/modules",
    "version": "1.0.0",
    "description": "Velm module loader — discovery, ir.module, install/sync, bundled modules (modules/)",
    "license": "LGPL-3.0-or-later",
    "type": "library",
    "require": {
        "php": "^8.3",
        "illuminate/database": "^13.0",
        "illuminate/support": "^13.0",
        "velmphp/core": "^1.0@RC",
        "velmphp/views": "^1.0@RC"
    },
    "autoload": {
        "psr-4": {
            "Velm\\Modules\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Velm\\Modules\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Velm\\Modules\\ModulesServiceProvider"]
        },
        "velm": {
            "bundled-modules-path": "modules"
        },
        "branch-alias": { "dev-main": "1.x-dev" }
    },
    "minimum-stability": "dev"
}
