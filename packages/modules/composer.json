{
    "name": "velmphp/modules",
    "description": "Velm module loader — discovery, ir.module, install/sync, bundled modules",
    "license": "LGPL-3.0-or-later",
    "type": "library",
    "require": {
        "php": "^8.3",
        "illuminate/database": "^13.0",
        "illuminate/support": "^13.0",
        "velmphp/core": "@dev",
        "velmphp/views": "@dev"
    },
    "autoload": {
        "psr-4": {
            "Velm\\Modules\\": "src/",
            "Velm\\Modules\\Base\\Models\\": "modules/base/models/",
            "Velm\\Modules\\Partners\\Models\\": "modules/partners/models/",
            "Velm\\Modules\\FileManager\\Models\\": "modules/file_manager/models/",
            "Velm\\Modules\\Workflow\\Models\\": "modules/workflow/models/",
            "Velm\\Modules\\ChangeManagement\\Models\\": "modules/change_management/models/",
            "Velm\\Modules\\Mail\\Models\\": "modules/mail/models/"
        }
    },
    "autoload-dev": {
        "psr-4": { "Velm\\Modules\\Tests\\": "tests/" }
    },
    "extra": {
        "laravel": {
            "providers": ["Velm\\Modules\\ModulesServiceProvider"]
        },
        "branch-alias": { "dev-main": "1.x-dev" }
    },
    "minimum-stability": "dev"
}
