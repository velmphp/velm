#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * @deprecated Use Laravel Artisan from your app root: php artisan velm:<command>
 *
 * Example: php artisan velm:migrate
 *          php artisan list velm
 */
fwrite(STDERR, <<<'TXT'
The Velm CLI is registered on Laravel Artisan, not as a standalone binary.

From your application root (e.g. apps/skeleton):

  php artisan velm:migrate
  php artisan velm:module:list
  php artisan velm:db:diff --module=partners
  php artisan list velm

See https://github.com/velmphp/velm/blob/main/CONTEXT.md

TXT);
exit(1);
