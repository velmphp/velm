{
    "name": "velmphp/ui",
    "description": "Velm UI — widget registry, Livewire components, Tailwind + Flowbite bundle",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.0",
        "velmphp/core": "^1.0",
        "velmphp/views": "^1.0",
        "velmphp/web": "^1.0",
        "livewire/livewire": "^4.0"
    },
    "autoload": { "psr-4": { "Velm\\Ui\\": "src/" } },
    "autoload-dev": {
        "psr-4": { "Velm\\Ui\\Tests\\": "tests/" }
    },
    "extra": {
        "laravel": {
            "providers": ["Velm\\Ui\\UiServiceProvider"]
        },
        "branch-alias": { "dev-main": "1.x-dev" }
    },
    "minimum-stability": "dev"
}
