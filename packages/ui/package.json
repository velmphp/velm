{
    "name": "velmphp-ui-styles",
    "private": true,
    "description": "Tailwind + Flowbite build for velm-ui shell (PyVelm parity)",
    "scripts": {
        "vendor": "mkdir -p ./resources/js && cp ./node_modules/flowbite/dist/flowbite.min.js ./resources/js/flowbite.min.js",
        "build:css": "tailwindcss -i ./resources/css/velm.src.css -o ./resources/css/velm.css --minify && npm run vendor",
        "dev:css": "tailwindcss -i ./resources/css/velm.src.css -o ./resources/css/velm.css --watch"
    },
    "dependencies": {
        "flowbite": "^3.1.2"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.0.0",
        "tailwindcss": "^4.0.0"
    }
}
