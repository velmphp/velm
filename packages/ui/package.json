{
    "name": "velmphp-ui-styles",
    "private": true,
    "description": "Tailwind + Flowbite build for velm-ui shell (PyVelm parity)",
    "scripts": {
        "vendor": "mkdir -p ./resources/js && cp ./node_modules/flowbite/dist/flowbite.min.js ./resources/js/flowbite.min.js",
        "build:js": "node scripts/build-widgets.mjs",
        "build": "tailwindcss -i ./resources/css/velm.src.css -o ./resources/css/velm.css --minify && npm run vendor && npm run build:js",
        "dev:css": "tailwindcss -i ./resources/css/velm.src.css -o ./resources/css/velm.css --watch"
    },
    "dependencies": {
        "@codemirror/commands": "^6.8.1",
        "@codemirror/lang-css": "^6.3.1",
        "@codemirror/lang-html": "^6.4.9",
        "@codemirror/lang-javascript": "^6.2.4",
        "@codemirror/lang-json": "^6.0.2",
        "@codemirror/lang-python": "^6.2.1",
        "@codemirror/language": "^6.11.0",
        "@codemirror/state": "^6.5.2",
        "@codemirror/theme-one-dark": "^6.1.2",
        "@codemirror/view": "^6.36.5",
        "@tiptap/core": "^2.11.5",
        "@tiptap/extension-highlight": "^2.27.2",
        "@tiptap/extension-image": "^2.27.2",
        "@tiptap/extension-link": "^2.11.5",
        "@tiptap/extension-placeholder": "^2.11.5",
        "@tiptap/extension-subscript": "^2.27.2",
        "@tiptap/extension-superscript": "^2.27.2",
        "@tiptap/extension-task-item": "^2.27.2",
        "@tiptap/extension-task-list": "^2.27.2",
        "@tiptap/extension-text-align": "^2.27.2",
        "@tiptap/extension-underline": "^2.27.2",
        "@tiptap/pm": "^2.11.5",
        "@tiptap/starter-kit": "^2.11.5",
        "codemirror": "^6.0.1",
        "flowbite": "^3.1.2",
        "tiptap-extension-resize-image": "^1.4.3"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.0.0",
        "esbuild": "^0.25.0",
        "tailwindcss": "^4.0.0"
    }
}
