{
    "name": "velmphp/velm-dev",
    "description": "Velm monorepo development workspace",
    "license": "LGPL-3.0-or-later",
    "type": "project",
    "require": {
        "php": "^8.3",
        "velmphp/framework": "@dev"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/phpstan": "^2.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "repositories": [
        { "type": "path", "url": "packages/*", "options": { "symlink": true } }
    ],
    "autoload-dev": {
        "psr-4": {
            "Velm\\Tests\\": "tests/",
            "Velm\\Modules\\Tests\\": "packages/modules/tests/",
            "Velm\\Core\\Tests\\": "packages/core/tests/",
            "Velm\\Filament\\Tests\\": "packages/filament/tests/",
            "Velm\\Framework\\Tests\\": "packages/framework/tests/",
            "Velm\\Views\\Tests\\": "packages/views/tests/",
            "Velm\\Web\\Tests\\": "packages/web/tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse --memory-limit=512M"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
