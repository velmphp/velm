{
    "name": "velmphp/velm-dev",
    "description": "Velm monorepo development workspace",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.3",
        "velmphp/framework": "^1.0@dev"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/phpstan": "^2.0"
    },
    "config": {
        "platform": {
            "php": "8.3.31"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "repositories": [
        { "type": "path", "url": "packages/*", "options": { "symlink": true } }
    ],
    "autoload-dev": {
        "psr-4": {
            "Velm\\Tests\\": "tests/",
            "Velm\\Modules\\Tests\\": "packages/modules/tests/",
            "Velm\\Core\\Tests\\": "packages/core/tests/",
            "Velm\\Admin\\Tests\\": "packages/admin/tests/",
            "Velm\\Framework\\Tests\\": "packages/framework/tests/",
            "Velm\\Views\\Tests\\": "packages/views/tests/",
            "Velm\\Web\\Tests\\": "packages/web/tests/",
            "Velm\\Ui\\Tests\\": "packages/ui/tests/",
            "Velm\\Console\\Tests\\": "packages/console/tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "pest --coverage-clover=coverage.xml",
        "test:coverage:report": "pest --coverage --coverage-clover=coverage.xml --min=78",
        "analyse": "phpstan analyse --memory-limit=512M",
        "build-ui": [
            "npm --prefix packages/ui ci",
            "npm --prefix packages/ui run build"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
