<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         cacheDirectory=".phpunit.cache">
    <testsuites>
        <testsuite name="Velm">
            <directory>tests</directory>
            <directory>packages/*/tests</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory suffix=".php">packages/admin/src</directory>
            <directory suffix=".php">packages/console/src</directory>
            <directory suffix=".php">packages/core/src</directory>
            <directory suffix=".php">packages/framework/src</directory>
            <directory suffix=".php">packages/modules/src</directory>
            <directory suffix=".php">packages/modules/modules</directory>
            <directory suffix=".php">packages/ui/src</directory>
            <directory suffix=".php">packages/views/src</directory>
            <directory suffix=".php">packages/web/src</directory>
        </include>
    </source>
</phpunit>
